{
  "name": "appsec-test",
  "version": "1.0.0",
  "description": "Test ",
  "main": "build/app.js",
  "scripts": {
    "copySwaggerDoc": "cpx \"src/swagger-docs/*.*\" build/server/swagger-docs",
    "copyConfig": "cpx \"src/config/*.json\" build/server/config",
    "start": "nodemon --watch src/**/*.ts --exec ts-node src/main.ts",
    "start:qas": "nodemon -V --exec ts-node src/main.ts --config nodemon-qas.json",
    "start:prod": "nodemon -V --exec ts-node src/main.ts --config nodemon-prod.json",
    "start:staging": "nodemon --watch src/**/*.ts --exec ts-node src/main.ts --config nodemon-staging.json",
    "startold": "npm run clean:build && npm run copySwaggerDoc && npm run copyConfig &&  tsc -p ./src && concurrently  \"nodemon build/server/main.js\"",
    "lint": "npm run tslint \"src/**/*.ts\"",
    "tslint": "tslint",
    "pree2e": "webdriver-manager update",
    "build:local": "tsc -p ./src",
    "build:dev": "npm run lint && npm run clean:dest && webpack --env dev --mode=production",
    "build:qas": "npm run lint && npm run clean:dest && webpack --env qas --mode=production",
    "build:beta": "npm run lint && npm run clean:dest && webpack --env beta --mode=production",
    "build:prod": "npm run lint && npm run clean:dest && webpack --env prod --mode=production",
    "clean:dest": "rimraf dist",
    "clean:build": "rimraf build",
    "test": "npm run lint && nyc mocha --timeout 15000 --recursive --compilers ts:ts-node/register -R spec --exit",
    "cover": "npm run test"
  },
  "keywords": [
    "typescript",
    "mocha",
    "sourcemaps",
    "node",
    "npm scripts",
    "tsc"
  ],
  "dependencies": {
    "@okta/jwt-verifier": "0.0.12",
    "@types/body-parser": "1.17.0",
    "@types/chai": "4.1.7",
    "@types/chai-http": "3.0.5",
    "@types/compression": "0.0.36",
    "@types/cors": "2.8.4",
    "@types/express": "4.16.0",
    "@types/lodash": "4.14.120",
    "@types/mocha": "5.2.5",
    "@types/node": "10.12.18",
    "agentkeepalive": "4.0.0",
    "async": "2.6.1",
    "body-parser": "1.18.3",
    "chai": "4.2.0",
    "chai-http": "4.2.1",
    "compression": "1.7.3",
    "cookie-parser": "1.4.3",
    "copy-webpack-plugin": "4.6.0",
    "cors": "2.8.5",
    "cpx": "1.5.0",
    "express": "4.16.4",
    "express-winston": "^2.5.0",
    "fs": "0.0.1-security",
    "httpreq": "0.4.24",
    "ip": "1.1.5",
    "joi": "14.3.1",
    "json-loader": "0.5.7",
    "jsonwebtoken": "8.4.0",
    "jwk-to-pem": "2.0.1",
    "lodash": "^4.17.15",
    "mocha": "5.2.0",
    "moment-timezone": "^0.5.27",
    "mysql2": "^1.6.5",
    "nconf": "0.10.0",
    "node-schedule": "^1.3.2",
    "nodemailer": "^6.1.1",
    "nodemailer-smtp-transport": "^2.7.4",
    "nyc": "11.3.0",
    "path": "0.12.7",
    "request": "2.87.0",
    "rimraf": "2.6.3",
    "sequelize": "4.42.0",
    "swagger-ui-express": "4.0.2",
    "tedious": "4.1.3",
    "ts-loader": "5.3.3",
    "ts-node": "^7.0.1",
    "typescript": "3.2.4",
    "typescript-string-operations": "^1.3.1",
    "webpack": "4.29.0",
    "webpack-cli": "^3.3.8",
    "webpack-node-externals": "1.7.2",
    "winston": "^2.4.1",
    "winston-daily-rotate-file": "^3.0.1"
  },
  "devDependencies": {
    "concurrently": "4.1.0",
    "convert-source-map": "1.6.0",
    "nodemon": "1.18.9",
    "tslint": "5.12.1",
    "tslint-sonarts": "1.9.0",
    "webdriver-manager": "12.1.1"
  },
  "nyc": {
    "check-coverage": true,
    "all": true,
    "extension": [
      ".ts"
    ],
    "include": [
      "test/**/*.test.ts",
      "src/**/*.ts"
    ],
    "reporter": [
      "html",
      "lcov",
      "text",
      "text-summary"
    ],
    "report-dir": "./reports/coverage"
  }
}
